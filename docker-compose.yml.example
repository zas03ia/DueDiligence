version: '3.8'

services:
  postgres:
    image: postgres:15
    container_name: due_diligence_db
    env_file: .env
    environment:
      POSTGRES_DB: ${POSTGRES_DB}
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./backend/migrations:/docker-entrypoint-initdb.d
    networks:
      - due_diligence_net

  redis:
    image: redis:7-alpine
    container_name: due_diligence_redis
    ports:
      - "6379:6379"
    networks:
      - due_diligence_net

volumes:
  postgres_data:

networks:
  due_diligence_net:
    driver: bridge